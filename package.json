{
  "name": "mirovine-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Frontend (Next.js) + Backend Studio (Sanity) in one GitHub repository",
  "scripts": {
    "dev:frontend": "npm --prefix frontend/my-app run dev",
    "build:frontend": "npm --prefix frontend/my-app run build",
    "start:frontend": "npm --prefix frontend/my-app run start",
    "lint:frontend": "npm --prefix frontend/my-app run lint",
    "dev:backend": "npm --prefix backend/penzija run dev",
    "build:backend": "npm --prefix backend/penzija run build",
    "start:backend": "npm --prefix backend/penzija run start",
    "dev": "npm run dev:frontend",
    "build": "npm run build:frontend"
  }
}
